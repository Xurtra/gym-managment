{
  "name": "@gym-platform/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch --conditions=development src/index.ts",
    "migrate": "tsx --conditions=development src/db/migrate.ts",
    "seed": "tsx --conditions=development src/db/seed.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@gym-platform/constants": "*",
    "@gym-platform/validation": "*",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
