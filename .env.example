# Base defaults
NODE_ENV=development

# API
PERSISTENCE_DRIVER=memory
API_HOST=0.0.0.0
API_PORT=4000
# Railway provides PORT automatically. API_PORT is for local/manual overrides.
PORT=
ACCESS_TOKEN_SECRET=local-dev-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Infrastructure
DATABASE_URL=postgres://gym:gym@localhost:5432/gym_platform
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_MOCK_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_ONBOARDING_REFRESH_URL=http://127.0.0.1:5173/?gymSlug=demo-strength-club#/dashboard
STRIPE_ONBOARDING_RETURN_URL=http://127.0.0.1:5173/?gymSlug=demo-strength-club#/dashboard

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:4000

# Worker
WORKER_NAME=gym-platform-worker
WORKER_POLL_INTERVAL_MS=1000
WORKER_ENQUEUE_BOOT_JOB=true
